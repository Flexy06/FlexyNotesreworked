<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Offizieller Splash Screen für den Dark Mode -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#141218</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.FlexyNotesreworked</item>
    </style>

    <style name="Theme.FlexyNotesreworked" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>